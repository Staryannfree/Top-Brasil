{
    "manifest_version": 3,
    "name": "Top Brasil - PowerCRM Bridge",
    "version": "1.0",
    "description": "Integração automática entre o CRM e PowerCRM usando a sessão ativa do navegador.",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://yfqrpfmoworgncfsqkgy.supabase.co/*",
        "https://app.powercrm.com.br/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon.png",
            "48": "icon.png",
            "128": "icon.png"
        }
    }
}